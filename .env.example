# Supabase Edge Function URL, e.g.
# https://YOUR_PROJECT.supabase.co/functions/v1/festival-admin
VITE_FESTIVAL_API_URL=

# Preferred: Supabase publishable key (safe to expose in a browser).
VITE_FESTIVAL_PUBLIC_KEY=

# Legacy fallback. Leave empty when using VITE_FESTIVAL_PUBLIC_KEY.
VITE_FESTIVAL_ANON_KEY=
